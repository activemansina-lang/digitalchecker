# Telegram
BOT_TOKEN=123456:your-telegram-bot-token
SUPPORT_CHAT_LINK=https://t.me/your_support_username

# Database (Railway injects this automatically if you attach the Postgres plugin;
# for local docker-compose it is overridden in docker-compose.yml)
DATABASE_URL=postgresql+asyncpg://digitalchecker:digitalchecker@localhost:5432/digitalchecker

# Redis (Railway injects this automatically if you attach the Redis plugin)
REDIS_URL=redis://localhost:6379/0

# Optional CoinGecko pro API key (raises rate limits)
COINGECKO_API_KEY=

LOG_LEVEL=INFO
DEFAULT_LANGUAGE=fa
